#!/usr/bin/env Rscript
suppressPackageStartupMessages({
library(grid)
})
input_path <- "docs/genomic_background_simulation_explanation.md"
output_path <- "docs/genomic_background_simulation_explanation.pdf"
wrap_with_prefix <- function(text, first_prefix, next_prefix, width) {
usable_width <- width - max(nchar(first_prefix), nchar(next_prefix))
wrapped <- strwrap(text, width = usable_width)
if (length(wrapped) == 0L) {
return(first_prefix)
}
c(
paste0(first_prefix, wrapped[[1]]),
if (length(wrapped) > 1L) {
paste0(next_prefix, wrapped[-1])
} else {
character(0)
}
)
}
wrap_report_lines <- function(lines, width = 92L) {
wrapped <- character(0)
in_code <- FALSE
for (line in lines) {
if (grepl("^```", line)) {
in_code <- !in_code
wrapped <- c(wrapped, line)
next
}
if (in_code || identical(line, "")) {
wrapped <- c(wrapped, line)
next
}
if (grepl("^# ", line)) {
wrapped <- c(wrapped, toupper(sub("^# ", "", line)), "")
next
}
if (grepl("^## ", line)) {
wrapped <- c(wrapped, sub("^## ", "", line), strrep("-", 72L), "")
next
}
if (grepl("^### ", line)) {
wrapped <- c(wrapped, sub("^### ", "", line), "")
next
}
if (grepl("^- ", line)) {
wrapped <- c(
wrapped,
wrap_with_prefix(
text = sub("^- ", "", line),
first_prefix = "* ",
next_prefix = "  ",
width = width
)
)
next
}
if (grepl("^[0-9]+\\. ", line)) {
prefix <- sub("^([0-9]+\\.).*$", "\\1 ", line)
body <- sub("^[0-9]+\\. ", "", line)
wrapped <- c(
wrapped,
wrap_with_prefix(
text = body,
first_prefix = prefix,
next_prefix = strrep(" ", nchar(prefix)),
width = width
)
)
next
}
wrapped <- c(wrapped, strwrap(line, width = width))
}
wrapped
}
render_text_pdf <- function(lines, path, lines_per_page = 48L) {
dir.create(dirname(path), recursive = TRUE, showWarnings = FALSE)
total_pages <- ceiling(length(lines) / lines_per_page)
pdf(path, width = 8.5, height = 11, family = "Courier")
on.exit(dev.off(), add = TRUE)
for (page_idx in seq_len(total_pages)) {
start_idx <- ((page_idx - 1L) * lines_per_page) + 1L
end_idx <- min(page_idx * lines_per_page, length(lines))
page_lines <- lines[start_idx:end_idx]
grid.newpage()
grid.text(
label = paste(page_lines, collapse = "\n"),
x = unit(0.05, "npc"),
y = unit(0.97, "npc"),
just = c("left", "top"),
gp = gpar(fontsize = 9)
)
grid.text(
label = sprintf("Page %d of %d", page_idx, total_pages),
x = unit(0.95, "npc"),
y = unit(0.03, "npc"),
just = c("right", "bottom"),
gp = gpar(fontsize = 8)
)
}
}
if (!file.exists(input_path)) {
stop("Missing input file: ", input_path)
}
setwd("~/Documents/MostafaviLab/Git/GeneExpression")
#!/usr/bin/env Rscript
suppressPackageStartupMessages({
library(grid)
})
input_path <- "docs/genomic_background_simulation_explanation.md"
output_path <- "docs/genomic_background_simulation_explanation.pdf"
wrap_with_prefix <- function(text, first_prefix, next_prefix, width) {
usable_width <- width - max(nchar(first_prefix), nchar(next_prefix))
wrapped <- strwrap(text, width = usable_width)
if (length(wrapped) == 0L) {
return(first_prefix)
}
c(
paste0(first_prefix, wrapped[[1]]),
if (length(wrapped) > 1L) {
paste0(next_prefix, wrapped[-1])
} else {
