params {
    // Inputs
    tpm_file     = "/gpfs/data/mostafavilab/sool/analysis/GeneExpression/20260125_salmon_nextflow/results/matrices/gene_tpm.tsv"
    counts_file  = "/gpfs/data/mostafavilab/sool/analysis/GeneExpression/20260125_salmon_nextflow/results/matrices/gene_counts.tsv"
    sdrf_url     = "https://www.ebi.ac.uk/arrayexpress/files/E-GEUV-1/E-GEUV-1.sdrf.txt"
    eur_pops     = ["British", "Finnish", "Tuscan", "Utah"]
    plink_prefix = "/gpfs/data/mostafavilab/shared_data/LDSC_data/1000G_EUR_Phase3_plink/1000G.EUR.QC.22"
    grm_prefix   = "genotype_grm"

    // GTEx-style filtering and covariate settings
    gtex_tpm_threshold = 0.1
    gtex_count_threshold = 6
    gtex_sample_frac_threshold = 0.2
    n_pcs = 5
    peer_nk = "auto"

    // Executables
    gcta_path = "/gpfs/data/mostafavilab/programs/GCTA/gcta-1.95.0-linux-kernel-3-x86_64/squashfs-root/AppRun"

    // Output
    outdir = "results"
}

// HPC scratch/work directory
workDir = "/gpfs/scratch/sl8085/nextflow_work/greml_production"

executor {
    queueSize = 500
    submitRateLimit = "10 sec"
}

profiles {
    slurm {
        process {
            executor = "slurm"
            queue = "mostafavilab"

            withName: FILTER_EUROPEANS {
                cpus = 1
                memory = "8 GB"
                time = "1h"
                beforeScript = "module load anaconda3/gpu/new; source activate r_peer"
            }

            withName: GENERATE_PCA {
                cpus = 4
                memory = "16 GB"
                time = "2h"
            }

            withName: PREPARE_PHENOTYPES {
                cpus = 4
                memory = "64 GB"
                time = "24h"
                beforeScript = "module load anaconda3/gpu/new; source activate r_peer"
            }

            withName: ESTIMATE_HERITABILITY {
                cpus = 1
                memory = "4 GB"
                time = "2h"
            }

            withName: SUMMARIZE_RESULTS {
                cpus = 1
                memory = "16 GB"
                time = "2h"
            }
        }
    }
}
